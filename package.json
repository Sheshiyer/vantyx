{
  "name": "panorama-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "apps/*",
    "worker",
    "cli"
  ],
  "scripts": {
    "dev": "concurrently -n worker,viewer,admin,console -c blue,green,magenta,cyan \"bun run --filter @panorama/worker dev\" \"bun run --filter @panorama/viewer dev\" \"bun run --filter @panorama/admin dev\" \"bun run --filter @panorama/console dev\"",
    "typecheck": "bun run --filter '@panorama/shared' --filter '@panorama/worker' --filter '@panorama/viewer' --filter '@panorama/admin' --filter '@panorama/console' typecheck",
    "typecheck:all": "bun run --filter '*' typecheck",
    "test": "bun test",
    "seed:marina": "bun scripts/generate-marina-config.ts",
    "seed:local": "bash scripts/seed-local.sh",
    "new-client": "bun cli/src/new-client.ts"
  },
  "devDependencies": {
    "@panorama/shared": "workspace:*",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.3"
  }
}
